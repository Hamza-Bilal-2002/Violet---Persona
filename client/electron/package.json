{
  "name": "persona-electron",
  "version": "0.1.0",
  "description": "Persona desktop overlay shell (Violet) — frameless transparent always-on-top window + tray",
  "main": "main.js",
  "private": true,
  "author": "Persona",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "npm --prefix ../frontend run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:frontend": "npm --prefix ../frontend run build",
    "dist": "npm run build:frontend && electron-builder --win",
    "dist:dir": "npm run build:frontend && electron-builder --win --dir",
    "postinstall": "node scripts/make-placeholder-icon.js && node scripts/make-app-icon.js"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.26.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.persona.violet",
    "productName": "Violet",
    "copyright": "Copyright © Persona",
    "directories": {
      "output": "../dist-app",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!.wwebjs_cache/${/*}",
      "!**/{.editorconfig,.eslintrc,.prettierrc,.git,.gitignore}"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/whatsapp-web.js/**",
      "**/node_modules/puppeteer/**",
      "**/node_modules/puppeteer-core/**"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        },
        {
          "target": "portable",
          "arch": "x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Violet"
    },
    "portable": {
      "artifactName": "Violet-${version}-portable.exe"
    }
  }
}
