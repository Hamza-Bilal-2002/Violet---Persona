# Copy to .env and fill in your real values. .env is gitignored.

# ============================================================
# LLM — cloud fallback (OpenAI)
# ============================================================
OPENAI_API_KEY=sk-...your_key_here...
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# LLM — provider selection
# ============================================================
# auto   = use local Ollama when reachable, else GPT (recommended for PC)
# local  = force Ollama (errors if not running)
# openai = force GPT (use this on machines without Ollama)
LLM_PROVIDER=auto

# The Ollama model tag to use. Must match what you pulled:
#   docker compose --profile local exec ollama ollama pull llama3.1:8b
LOCAL_LLM_MODEL=llama3.1:8b

# ============================================================
# Server
# ============================================================
LOG_LEVEL=INFO

# CORS — add origins here when connecting from other devices on the network.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
