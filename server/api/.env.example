# Copy to .env and fill in your real values. .env is gitignored.

# ============================================================
# LLM — cloud fallback (OpenAI)
# ============================================================
OPENAI_API_KEY=sk-...your_key_here...
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# LLM — NVIDIA NIM (cloud-hosted, OpenAI-compatible brain)
# ============================================================
# A far stronger Tier-1 than a CPU-bound local model. Get an nvapi-… key
# from https://build.nvidia.com. Selected at runtime from Settings →
# AI Model (never used automatically). Leave the key blank to disable.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Recommended for Violet (clean tool-calling, terse replies):
#   meta/llama-3.3-70b-instruct
# Stronger reasoning (verbose — runs with thinking off):
#   nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ============================================================
# LLM — provider selection
# ============================================================
# auto   = use local Ollama when reachable, else GPT (recommended for PC)
# local  = force Ollama (errors if not running)
# nvidia = force the NVIDIA NIM model above
# openai = force GPT (use this on machines without Ollama)
# NOTE: the active brain is also switchable live from Settings → AI Model,
# which persists to /data/llm_runtime.json and overrides this on next start.
LLM_PROVIDER=auto

# The Ollama model tag to use. Must match what you pulled:
#   docker compose --profile local exec ollama ollama pull llama3.1:8b
LOCAL_LLM_MODEL=llama3.1:8b

# ============================================================
# Server
# ============================================================
LOG_LEVEL=INFO

# CORS — add origins here when connecting from other devices on the network.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
